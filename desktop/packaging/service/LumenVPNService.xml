<service>
  <id>LumenVPN</id>
  <name>Lumen VPN Service</name>
  <description>Lumen VPN local runtime control service.</description>
  <executable>%BASE%\..\jre\bin\java.exe</executable>
  <arguments>-cp "%BASE%\..\lib\*" tel.lumentech.vpn.desktop.WindowsServiceKt</arguments>
  <logpath>%ProgramData%\LumenVPN\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10485760</sizeThreshold>
    <keepFiles>5</keepFiles>
  </log>
  <onfailure action="restart" delay="5 sec" />
</service>
